# ==========================================
# Core Infrastructure Switch
# ==========================================
STORAGE_TYPE=postgres
# PUBLISHER_TYPE=nats
PUBLISHER_TYPE=kafka

# ==========================================
# Unified Connection Strings
# ==========================================
STORAGE_URL=postgres://postgres:postgres@localhost:5432/postgres
# PUBLISHER_URL=nats://localhost:4222
PUBLISHER_URL=kafka://localhost:9092

# ==========================================
# Engine Tuning (Postgres Side)
# ==========================================
POLL_INTERVAL=100ms
BATCH_SIZE=100
LEASE_TIMEOUT=1s
SERVER_PORT=:9000
ENVIRONMENT=production
RELAY_ID=relay-worker-01

# ==========================================
# Kafka Specific Tuning (Relay Optimized)
# ==========================================
# Critical Performance Tuning
KAFKA_BATCH_SIZE=1
KAFKA_BATCH_BYTES=10485760
KAFKA_BATCH_TIMEOUT=10ms

# Safety & Compression
KAFKA_COMPRESSION=none
KAFKA_REQUIRED_ACKS=all
KAFKA_ASYNC=false

# Timeouts & Retries
KAFKA_MAX_ATTEMPTS=5
KAFKA_WRITE_TIMEOUT=10s
KAFKA_READ_TIMEOUT=10s

# ==========================================
# Observability (OpenTelemetry)
# ==========================================
OTEL_SDK_DISABLED=true
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_BSP_EXPORT_TIMEOUT=30000
OTEL_BSP_SCHEDULE_DELAY=5000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ==========================================
# NATS Specific Tuning (If toggled)
# ==========================================
NATS_FLUSH_TIMEOUT=5s