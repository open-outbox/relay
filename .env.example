# ==========================================
# Core Infrastructure Switch
# ==========================================
# Options: postgres, mysql, memory
STORAGE_TYPE=postgres

# The database table name to monitor for events
STORAGE_TABLE_NAME=openoutbox_events

# Options: nats, kafka, redis, stdout
PUBLISHER_TYPE=stdout

# ==========================================
# Unified Connection Strings
# ==========================================
# Format: postgres://user:pass@host:5432/db
STORAGE_URL=postgres://postgres:postgres@localhost:5432/postgres
# Format: localhost:9092,localhost:9091 or nats://localhost:4222
# or redis://localhost:6379
# PUBLISHER_URL=redis://localhost:6379
# PUBLISHER_URL=localhost:9092
PUBLISHER_URL=nats://localhost:4222

# ==========================================
# Engine Tuning (Outbox Polling)
# ==========================================
# Frequency of DB polling for new events
POLL_INTERVAL=500ms
# Max events to process in a single iteration
BATCH_SIZE=100
# Duration before a "DELIVERING" event is considered stuck
LEASE_TIMEOUT=3m
# Number of expired leases to reset per cleanup cycle
REAP_BATCH_SIZE=100
# The time to wait between attempts to connect to the publisher (NATS, Kafka, etc.)
# during the startup phase if the broker is unreachable.
PUBLISHER_CONNECT_RETRY_INTERVAL=5s
# HTTP Server for health checks and metrics
SERVER_PORT=:8080
# Mode: production or development
ENVIRONMENT=production
# Unique ID for this instance (Default: os.Hostname())
RELAY_ID=relay-worker-01

# ==========================================
# Reliability & Self-Healing (Backoff)
# ==========================================
# Max attempts before an event is marked DEAD
RETRY_MAX_ATTEMPTS=25
# Starting delay for exponential backoff
RETRY_BASE_DELAY=1s
# Maximum delay cap for backoff
RETRY_MAX_DELAY=24h
# Randomness factor (0.15 = 15% jitter)
RETRY_JITTER=0.15


# ==========================================
# Kafka Specific Tuning (Relay Optimized)
# ==========================================
# Critical: Set to 1 to ensure the Relay's internal batching/polling logic remains the
# primary driver of delivery frequency and ordering.
KAFKA_BATCH_SIZE=1

# Maximum size in bytes of a single batch request sent to the Kafka broker.
KAFKA_BATCH_BYTES=10485760

# How long to wait for a batch to fill before sending (minimal for low latency).
KAFKA_BATCH_TIMEOUT=10ms

# --- Safety & Throughput ---

# Algorithm used to compress messages. 'snappy' offers a good balance of CPU vs ratio.
# Options: none, gzip, snappy, lz4, zstd
KAFKA_COMPRESSION=snappy

# Number of broker replicas that must acknowledge the message before it's considered 'sent'.
# Options: all (highest safety), one (faster), none (fire-and-forget)
KAFKA_REQUIRED_ACKS=all

# When false, the publisher blocks until an ACK is received, ensuring "At-Least-Once" delivery.
KAFKA_ASYNC=false

# --- Timeouts & Retries ---

# Maximum number of retry attempts for a single batch before reporting a publish error.
KAFKA_MAX_ATTEMPTS=5

# The deadline for the broker to acknowledge a write request.
KAFKA_WRITE_TIMEOUT=10s

# The deadline for reading a response or metadata from the Kafka broker.
KAFKA_READ_TIMEOUT=10s

# The maximum time allowed to establish the initial TCP connection and handshake with brokers.
KAFKA_CONNECTION_TIMEOUT=10s

# ==========================================
# NATS Specific Tuning
# ==========================================
# The maximum time to wait for the NATS broker to acknowledge a published message (JetStream ACK).
NATS_PUBLISH_TIMEOUT=5s

# The maximum time allowed to establish the initial connection and handshake with the NATS server.
NATS_CONNECTION_TIMEOUT=10s

# ==========================================
# Redis Specific Tuning
# ==========================================
# How long to wait for the initial 'Ping' on startup
REDIS_CONNECTION_TIMEOUT=5s

# How long to wait for each 'XADD' during the engine loop
REDIS_WRITE_TIMEOUT=1s

# ==========================================
# Observability (OpenTelemetry / OTel)
# ==========================================
# Traces Exporter: Defines the destination for trace data.
# Example: otlp, console, none
OTEL_TRACES_EXPORTER=none

# Metrics Exporter: Defines the destination for metric data.
# Example: otlp, console, prometheus, none
OTEL_METRICS_EXPORTER=none

# OTLP Endpoint: The address of your OpenTelemetry Collector or Backend.
# Example: http://localhost:4317 (gRPC), http://localhost:4318 (HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# OTLP Protocol: The transport protocol for the OTLP exporter.
# Example: grpc, http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Batch Span Processor (BSP) - Export Timeout (ms):
# Maximum time the SDK will wait for a batch of spans to be exported.
# Example: 30000 (30s)
OTEL_BSP_EXPORT_TIMEOUT=30000

# Batch Span Processor (BSP) - Schedule Delay (ms):
# The interval between two consecutive exports. Smaller values reduce
# memory usage but increase CPU and network overhead.
# Example: 5000 (5s)
OTEL_BSP_SCHEDULE_DELAY=5000

# ==========================================
# Local Development Only (Overridable)
# ==========================================
# These are used by the Makefile and local scripts to sync
# your Relay, Producer, and Infrastructure setup.

# The base name used for publisher subject/topics/etc.
LOCAL_TEST_TOPIC=openoutbox.events.v1

# The JetStream stream name for NATS
LOCAL_NATS_STREAM=OEPNOUTBOX_EVENTS

# Used by 'make test-otel' to simulate traffic
LOCAL_OTEL_TEST_TRACE_COUNT=100

# How many records per batch should be inserted by the producer
LOCAL_PRODUCER_BATCH_SIZE=10000

# The interval between each bach insertion
LOCAL_PRODUCER_INTERVAL=1s
